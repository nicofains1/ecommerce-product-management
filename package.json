{
  "name": "ecommerce-product-management",
  "version": "1.0.0",
  "private": true,
  "description": "Fullstack TypeScript monorepo for showing and managing eCommerce products",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "format": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "22.13.14",
    "eslint": "9.39.4",
    "prettier": "3.9.4",
    "turbo": "2.10.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0"
  }
}
